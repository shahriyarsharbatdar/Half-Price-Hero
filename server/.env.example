# Copy to .env — the server runs without a key (chef's tips fall back to rule-based)
ANTHROPIC_API_KEY=

# Shared secret the daily scraper (../scraper/) sends as a Bearer token to
# POST /api/admin/specials. Generate one with: openssl rand -hex 32
# Must match the SCRAPER_TOKEN secret set in the GitHub Actions workflow.
SCRAPER_TOKEN=

# Optional overrides
PORT=3001
